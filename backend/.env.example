SECRET_KEY=change-me
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=daily_scrum
MYSQL_USER=root
MYSQL_PASSWORD=password
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token
JIRA_JQL=project = MCUBETECH AND status NOT IN ("Roadmap Candidate", Resolved, Canceled, Closed, "Ticket Shelved") AND "Product [Dropdown]" NOT IN ("mcube_mobility", "Air Arabia") AND created >= "2025-01-01"
